{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "gpt-4",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "playwright",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vercel",
        "repo": "next.js",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vitejs",
        "repo": "vite",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "LWN.net (subscriber full-text)",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        }
      ],
      "users": [
        {
          "username": "iamthatis",
          "enabled": true,
          "sort": "new",
          "fetch_limit": 10
        }
      ],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "equities",
          "symbols": ["AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA"]
        }
      ]
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    },
    "ata": {
      "enabled": false,
      "base_url": "https://ata.atatech.org",
      "hot_path": "/api/v1/recommend/dayHotArticle",
      "cookie_source": "applescript",
      "chrome_domain": "ata.atatech.org",
      "chrome_cookie_file": null,
      "chrome_user_data_dir": "~/Library/Application Support/Google/Chrome",
      "chrome_profile_directory": "Profile 1",
      "headless": false,
      "cookie_env": "ATA_COOKIE",
      "xsrf_token_env": "ATA_XSRF_TOKEN",
      "fetch_limit": 5,
      "fetch_detail": true,
      "category": "ata-hot"
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": null,
    "category_groups": {},
    "default_group": "other",
    "default_group_limit": null
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  },
  "dingtalk": {
    "enabled": false,
    "app_key_env": "DINGTALK_APP_KEY",
    "app_secret_env": "DINGTALK_APP_SECRET",
    "robot_code_env": "DINGTALK_ROBOT_CODE",
    "open_conversation_id_env": "DINGTALK_OPEN_CONVERSATION_ID",
    "msg_key": "sampleMarkdown",
    "message_title": "Horizon 每日速递",
    "languages": ["zh"]
  }
}
